# SpeechFlow local development example environment

# Flask / app
SECRET_KEY=dev

# Database
DATABASE_URL=postgresql+psycopg2://speechflow:speechflow@localhost:5432/speechflow

# Hugging Face (required for diarization)
HF_TOKEN=

# Whisper
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Diarization
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1

# Logging
LOG_LEVEL=INFO

# Optional debugging
DIARIZATION_DEBUG=false

# Optional dev-only cache hygiene
PYTHONDONTWRITEBYTECODE=1

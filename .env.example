# SpeechFlow local development example environment

# Flask / app
SECRET_KEY=dev

# Database
DATABASE_URL=postgresql+psycopg2://speechflow:speechflow@localhost:5432/speechflow

# Speech models
HF_TOKEN=
WHISPER_MODEL=small.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Optional dev-only cache hygiene
# Set to 1 in your local shell or env file if you want to suppress __pycache__/.pyc writes.
PYTHONDONTWRITEBYTECODE=1

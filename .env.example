# SpeechFlow local development example environment

# Flask / app
SECRET_KEY=dev

# Database
DATABASE_URL=postgresql+psycopg2://speechflow:speechflow@localhost:5432/speechflow
POSTGRES_PASSWORD=speechflow

# Hugging Face (required for diarization)
HF_TOKEN=

# Whisper (use 'small' for multilingual/Hindi-English, 'small.en' for English-only)
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Diarization
DIARIZATION_MODEL=pyannote/speaker-diarization-community-1

# Logging
LOG_LEVEL=INFO

# Optional debugging
DIARIZATION_DEBUG=false

# Optional dev-only cache hygiene
PYTHONDONTWRITEBYTECODE=1

# Authentication
ADMIN_PASSWORD=your_secure_password_here

# Ollama (local LLM for intelligence + translation)
# Model for fast tasks like summaries, classification, MOMs
OLLAMA_MODEL=qwen2.5:3b
# Model for heavy natural language tasks like translation
TRANSLATION_MODEL=qwen2.5:7b

# Full URL to Ollama generate endpoint (default: http://localhost:11434/api/generate)
# OLLAMA_ENDPOINT=http://localhost:11434/api/generate
# Max seconds to wait for a single Ollama request (default: 3600)
OLLAMA_TIMEOUT_SECONDS=3600
# Streaming Audio Buffer (Prevents OOM on long recordings or stalled transcription)
# Max buffer size in MB before stream is force-ended (default: 200)
MAX_BUFFER_MB=200
